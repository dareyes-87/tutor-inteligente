# ===== PostgreSQL =====
POSTGRES_USER=tutor
POSTGRES_PASSWORD=cambia_esta_contrasena_por_una_segura
POSTGRES_DB=tutor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== ChromaDB =====
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ===== Together AI =====
TOGETHER_API_KEY=pon_aqui_tu_api_key
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# ===== Modelo fine-tuned (Modal) — A/B por grado, objetivo específico 3 de tesis =====
# Vacío = feature apagada. Si se llena, MODAL_FINETUNED_GRADOS decide qué
# estudiantes (por grado_id) se enrutan al fine-tuned; el resto sigue con Together.
MODAL_FINETUNED_URL=
MODAL_FINETUNED_MODEL_NAME=tutor-finetuned
MODAL_FINETUNED_API_KEY=
MODAL_FINETUNED_GRADOS=
MODAL_FINETUNED_TIMEOUT_SEGUNDOS=200

# ===== JWT (Seguridad) =====
# Genera una clave aleatoria con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== Admin seed =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== Almacenamiento =====
BOOKS_DIR=/data/books
